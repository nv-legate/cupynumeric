#!/usr/bin/env bash

quiet_legate_conda_retry() {
    LEGATE_CONDA_RETRY_QUIET=1 legate-conda-retry "$@"
}

setup_env() {
    set -euo pipefail

    conda config --set channel_priority strict
    export DEBIAN_FRONTEND=non-interactive

    # Run package updates and install packages
    if [[ -z "${SLURM_JOB_ID:-}" ]]; then
        apt-get -qq update >/dev/null
        apt-get -qq install -y numactl make >/dev/null
    else
        # Set unlimited locked memory for UCX/GPU operations
        # Must be set here otherwise legate-issue will fail
        ulimit -l unlimited
    fi

    legate-conda-retry search --override-channels -c "${ARTIFACTS_DIR}/conda-build/cupynumeric" --info cupynumeric

    # This requires strict channel priority to work (prioritize local channel)
    local create_args=(
        create
        -y
        -n legate
        -c "${ARTIFACTS_DIR}/conda-build/cupynumeric"
        -c "${ARTIFACTS_DIR}/conda-build/legate"
        -c conda-forge
        legate
        cupynumeric
    )
    quiet_legate_conda_retry "${create_args[@]}"
}

setup_test_env() {
    quiet_legate_conda_retry install -y \
        "clang-tools>=8" "clang>=8" colorama coverage mock pre-commit \
        pytest-cov pytest-mock "pytest" types-docutils pynvml psutil pip

    if [[ "${CUPY_REQUIRED_FOR_TESTS:-0}" == "1" ]]; then
        quiet_legate_conda_retry install -y cupy
    fi

    hash -r
    python -m pip install --disable-pip-version-check array-api-compat tifffile
}

setup_docs_env() {
    quiet_legate_conda_retry install -y pandoc doxygen pip
    hash -r
    python -m pip install \
        --disable-pip-version-check \
        ipython jinja2 "markdown<3.4.0" myst-parser nbsphinx \
        sphinx-copybutton "sphinx>=8" nvidia-sphinx-theme cffi
}

setup_mypy_env() {
    quiet_legate_conda_retry install -y \
        "mypy>=0.961" jinja2 nbsphinx sphinx-copybutton \
        "sphinx>=4.4.0" types-docutils scipy-stubs
}

setup_unit_env() {
    quiet_legate_conda_retry install -y pytest pytest-mock mock cffi
}

run_legate_issue() {
    if command -v "legate-issue" &> /dev/null; then
      legate-issue
    else
      echo "WARNING: legate-issue not found."
    fi
}

test_cupynumeric() {
    set -eo pipefail

    if [[ $# -eq 0 ]]; then
        echo "Missing command: expected sbatch, test, mypy, docs, unit, or cpp" >&2
        return 2
    fi
    local command="$1"

    . conda-utils;
    export CONDA_ENV=legate

    setup_env;

    activate_conda_env;
    if [[ "${LEGATE_CI_VERBOSE:-0}" == "1" ]]; then
        conda_info;
    fi

    cd "${REPO_DIR}";

    local workers_args=()
    if command -v nvidia-smi &> /dev/null; then
        gpu_count=$(nvidia-smi --query-gpu=name --format=csv,noheader | wc -l)
        if [ "$gpu_count" -ge 2 ]; then
            workers_args=(-j 1)
        fi
    fi

    local test_verbose_args=()
    if [[ "${LEGATE_CI_VERBOSE:-0}" == "1" ]]; then
        test_verbose_args=(-vv)
    fi

    case "${command}" in
        sbatch)
            echo "Executing sbatch tests..."
            shift;
            CUPY_REQUIRED_FOR_TESTS=0
            if [[ " $* " == *" --use cuda "* ]]; then
                CUPY_REQUIRED_FOR_TESTS=1
            fi
            setup_test_env;
            run_legate_issue;
            # when sourced, we just return
            if [[ "${BASH_SOURCE[0]}" != "${0}" ]]; then
                return 0
            fi
            ;;
        "test")
            echo "Executing tests..."
            shift;
            CUPY_REQUIRED_FOR_TESTS=0
            if [[ " $* " == *" --use cuda "* ]]; then
                CUPY_REQUIRED_FOR_TESTS=1
            fi
            setup_test_env;
            run_legate_issue;
            ./test.py "${workers_args[@]}" "${test_verbose_args[@]}" --timeout 600 "$@"
            ;;
        "mypy")
            echo "Installing and executing mypy..."
            shift;
            setup_mypy_env;
            run_legate_issue;
            mypy cupynumeric
            ;;
        "docs")
            echo "Building docs..."
            shift;
            setup_docs_env;
            run_legate_issue;
            cd docs/cupynumeric
            make clean html
            # ls -lah .
            echo Copying artifacts
            cd build/html
            cp -r . "${OUTPUT_ARTIFACTS_DIR}"
            ;;
        "unit")
            echo "Running Unit tests..."
            shift;
            setup_unit_env;
            run_legate_issue;
            LEGATE_AUTO_CONFIG=0 pytest tests/unit examples/_benchmark/tests
            ;;
        "cpp")
            echo "Running CPP tests..."
            shift;
            run_legate_issue;
            export LD_LIBRARY_PATH=${CONDA_PREFIX}/lib/legate/deps:${LD_LIBRARY_PATH:-}
            REALM_BACKTRACE=1 LEGATE_TEST=1 "${CONDA_PREFIX}/bin/cpp_tests"
            ;;
        *)
            echo "Invalid command: ${command}"
            return 1
            ;;
    esac
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    (test_cupynumeric "$@");
fi
